# ══════════════════════════════════════════════════════════════
#  InvenTrack — Environment Variables
#  Copy this file to .env and fill in your own values.
#  .env is gitignored and will NOT be committed.
# ══════════════════════════════════════════════════════════════

# ── Supabase / PostgreSQL ─────────────────────────────────────
DB_URL=jdbc:postgresql://<your-supabase-host>:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.<your-supabase-project-ref>
DB_PASSWORD=your_supabase_db_password

# ── JWT (use a long random string, 32+ chars) ─────────────────
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-at-least-256-bits

# ── CORS (comma-separated allowed frontend origins) ───────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,https://your-app.vercel.app

# ── Server port (default 8080) ────────────────────────────────
PORT=8080
